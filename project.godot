[input_devices]

pointing/android/enable_long_press_as_right_click=true

[internationalization]

rendering/text_driver="ICU / HarfBuzz / Graphite (Built-in)"

[rendering]

rendering_device/staging_buffer/max_size_mb=256
rendering_device/pipeline_cache/save_chunk_size_mb=16.0
textures/canvas_textures/default_texture_filter=0
textures/webp_compression/compression_method=4
textures/webp_compression/lossless_compression_factor=100.0
textures/default_filters/anisotropic_filtering_level=0
camera/depth_of_field/depth_of_field_bokeh_shape=0
camera/depth_of_field/depth_of_field_bokeh_quality=0
environment/ssao/quality=1
environment/ssil/quality=0
anti_aliasing/screen_space_roughness_limiter/enabled=false
scaling_3d/fsr_sharpness=0.2
2d/sdf/scale=2

