; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="2D Magic"
run/main_scene="uid://pfn5qd08mrdy"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/flush_stdout_on_print.debug=false
run/delta_smoothing=false
boot_splash/image="uid://de2plofonitoi"
config/icon="uid://ckjkjeff6rac8"

[autoload]

Character="*res://Scripts/Global Scripts/Character.gd"
Global="*res://Scripts/Global Scripts/Global.gd"
Math="*res://Scripts/Global Scripts/Math.gd"
Tool="*res://Scripts/Global Scripts/Tool.gd"

[debug]

settings/physics_interpolation/enable_warnings=false
file_logging/enable_file_logging.pc=false
gdscript/warnings/int_as_enum_without_cast=0
shader_language/warnings/unused_uniform=false

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/energy_saving/keep_screen_on=false
window/stretch/mode="viewport"
window/vsync/vsync_mode=0
mouse_cursor/custom_image="uid://bt0nt860cwobc"

[editor]

movie_writer/mjpeg_quality=0.5

[editor_plugins]

enabled=PackedStringArray()

